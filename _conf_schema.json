{
  "users": {
    "type": "template_list",
    "description": "提示词注入规则列表（聊天中发送 /tsc help 查看指令帮助）",
    "templates": {
      "user": {
        "name": "注入规则",
        "hint": "添加一条注入规则：QQ号 + 自定义提示词内容",
        "display_item": "target_qq",
        "items": {
          "target_qq": {
            "description": "QQ号",
            "type": "string",
            "default": ""
          },
          "inject_text": {
            "description": "注入的提示词",
            "type": "text",
            "hint": "该用户发消息时自动追加到系统提示词的内容",
            "default": ""
          },
          "enabled": {
            "description": "是否启用",
            "type": "bool",
            "default": true
          }
        }
      }
    }
  }
}
